@model ShopNest.Web.ViewModels.Category.CategoryIndexViewModel
@{
    ViewData["Title"] = "Categories Management - ShopNest Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="admin-container">
    <div class="admin-header">
        <h1><i class="fas fa-layer-group"></i> Categories Management</h1>
        <div class="admin-actions">
            <form method="get" class="search-form" asp-action="Index">
                <div class="input-icon">
                    <i class="fas fa-search"></i>
                    <input type="text" name="searchTerm" placeholder="Search categories..."
                           value="@Model.SearchTerm" aria-label="Search categories">
                </div>
            </form>
            <a href="@Url.Action("Create", "Category")" class="btn-primary">
                <i class="fas fa-plus-circle"></i> Create New Category
            </a>
        </div>
    </div>

    <div class="admin-card">
        <div class="card-header">
            <h2>Categories List</h2>
            <div class="header-info">
                <span class="badge">@Model.TotalCount Categories</span>
            </div>
        </div>
        
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }
            
            @if (Model.Categories.Any())
            {
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Products</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model.Categories)
                            {
                                <tr>
                                    <td>
                                        <div class="category-image">
                                            @if (!string.IsNullOrEmpty(category.ImagePath))
                                            {
                                                <img src="@category.ImagePath" alt="@category.Name" onerror="this.src='/images/default-category.png'">
                                            }
                                            else
                                            {
                                                <div class="no-image">
                                                    <i class="fas fa-image"></i>
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-name">
                                            <h4>@category.Name</h4>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-description">
                                            @if (!string.IsNullOrEmpty(category.Description) && category.Description.Length > 100)
                                            {
                                                <span>@category.Description.Substring(0, 100)...</span>
                                            }
                                            else
                                            {
                                                <span>@category.Description</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-products">
                                            <span class="badge">@category.ProductsCount</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-status">
                                            @if (category.IsActive)
                                            {
                                                <span class="status active"><i class="fas fa-check-circle"></i> Active</span>
                                            }
                                            else
                                            {
                                                <span class="status inactive"><i class="fas fa-times-circle"></i> Inactive</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="category-actions">
                                            <a href="@Url.Action("Edit", "Category", new { id = category.Id })"
                                                   class="action-btn edit" title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Details", "Category", new { id = category.Id })"
                                                   class="action-btn view" title="Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <button type="button"
                                                    class="action-btn delete"
                                                    title="Delete"
                                                    data-category-id="@category.Id"
                                                    data-category-name="@category.Name">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="pagination-container">
                        <ul class="pagination">
                            @if (Model.CurrentPage > 1)
                            {
                                <li>
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, page = 1 })">
                                        <i class="fas fa-angle-double-left"></i>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, page = Model.CurrentPage - 1 })">
                                        <i class="fas fa-angle-left"></i>
                                    </a>
                                </li>
                            }
                            
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="@(i == Model.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, page = i })">@i</a>
                                </li>
                            }
                            
                            @if (Model.CurrentPage < Model.TotalPages)
                            {
                                <li>
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, page = Model.CurrentPage + 1 })">
                                        <i class="fas fa-angle-right"></i>
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, page = Model.TotalPages })">
                                        <i class="fas fa-angle-double-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-layer-group"></i>
                    <h3>No categories found</h3>
                    <p>@(string.IsNullOrEmpty(Model.SearchTerm) ? "There are no categories in the system yet." : $"No categories match your search: '{Model.SearchTerm}'")</p>
                    <a href="@Url.Action("Create", "Category")" class="btn-primary">
                        <i class="fas fa-plus-circle"></i> Create Your First Category
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal" id="deleteModal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-trash-alt"></i> Confirm Deletion</h3>
            <span class="modal-close">&times;</span>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to delete the category <strong id="categoryName"></strong>?</p>
            <p class="warning-text">
                <i class="fas fa-exclamation-triangle"></i> Warning: This action cannot be undone. All products in this category will be affected.
            </p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-secondary modal-close-btn">Cancel</button>
            <form id="deleteForm" method="post" action="@Url.Action("DeleteConfirmed", "Category")">
                <input type="hidden" name="id" id="categoryIdToDelete">
                <button type="submit" class="btn-danger">
                    <i class="fas fa-trash-alt"></i> Delete
                </button>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Admin Container */
        .admin-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

            .admin-header h1 {
                font-size: 1.8rem;
                color: var(--primary-dark);
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

        .admin-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        /* Search Form */
        .search-form {
            display: flex;
            position: relative;
        }

        .input-icon {
            position: relative;
            width: 300px;
        }

            .input-icon i {
                position: absolute;
                left: 1rem;
                top: 50%;
                transform: translateY(-50%);
                color: var(--text-dim);
                font-size: 1rem;
            }

            .input-icon input {
                width: 100%;
                padding: 0.7rem 1rem 0.7rem 2.5rem;
                border: 1.5px solid var(--border-color);
                border-radius: 12px;
                font-size: 0.95rem;
                transition: var(--transition);
            }

                .input-icon input:focus {
                    outline: none;
                    border-color: var(--primary);
                    box-shadow: 0 0 0 4px rgba(27, 67, 50, 0.08);
                }

        /* Admin Card */
        .admin-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            margin-bottom: 2rem;
        }

        .card-header {
            padding: 1.5rem;
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

            .card-header h2 {
                font-size: 1.4rem;
                color: var(--primary-dark);
                margin: 0;
            }

        .header-info {
            display: flex;
            gap: 0.75rem;
        }

        .badge {
            background: var(--primary-light);
            color: var(--primary-dark);
            padding: 0.4rem 0.8rem;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            padding: 0.7rem 1.2rem;
            border-radius: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .btn-primary:hover {
                background: var(--primary-mid);
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
            }

        /* Admin Table */
        .table-responsive {
            overflow-x: auto;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
        }

            .admin-table th {
                background: var(--bg-surface);
                padding: 1rem;
                text-align: left;
                font-weight: 600;
                color: var(--text-main);
                border-bottom: 2px solid var(--border-color);
            }

            .admin-table td {
                padding: 1rem;
                border-bottom: 1px solid var(--border-color);
                vertical-align: middle;
            }

            .admin-table tr:last-child td {
                border-bottom: none;
            }

            .admin-table tr:hover {
                background: var(--primary-pale);
            }

        /* Category Image */
        .category-image {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            overflow: hidden;
            background: var(--bg-surface);
        }

            .category-image img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .no-image {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-surface);
            color: var(--text-dim);
        }

        /* Category Name */
        .category-name h4 {
            font-weight: 600;
            color: var(--text-main);
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 200px;
        }

        /* Category Description */
        .category-description {
            color: var(--text-muted);
            font-size: 0.9rem;
            max-width: 300px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Category Products */
        .category-products .badge {
            background: var(--primary-light);
            color: var(--primary-dark);
            padding: 0.3rem 0.7rem;
        }

        /* Category Status */
        .category-status .status {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.3rem 0.7rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .category-status .active {
            background: rgba(45, 164, 78, 0.15);
            color: #2da44e;
        }

        .category-status .inactive {
            background: rgba(201, 150, 59, 0.15);
            color: #c9963b;
        }

        /* Category Actions */
        .category-actions {
            display: flex;
            gap: 0.75rem;
        }

        .action-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            background: var(--bg-surface);
            color: var(--text-muted);
        }

            .action-btn:hover {
                transform: scale(1.1);
            }

            .action-btn.edit {
                color: var(--primary);
            }

                .action-btn.edit:hover {
                    background: rgba(45, 106, 79, 0.1);
                    color: var(--primary-mid);
                }

            .action-btn.view {
                color: var(--accent);
            }

                .action-btn.view:hover {
                    background: rgba(201, 150, 59, 0.1);
                    color: var(--accent);
                }

            .action-btn.delete {
                color: var(--error);
            }

                .action-btn.delete:hover {
                    background: rgba(192, 57, 43, 0.1);
                    color: var(--error);
                }

        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: center;
            margin-top: 2rem;
        }

        .pagination {
            display: flex;
            list-style: none;
            gap: 0.5rem;
        }

            .pagination li {
                display: flex;
            }

                .pagination li a {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    width: 40px;
                    height: 40px;
                    border-radius: 10px;
                    background: var(--bg-surface);
                    color: var(--text-muted);
                    text-decoration: none;
                    transition: var(--transition);
                }

                .pagination li.active a {
                    background: var(--primary);
                    color: white;
                    font-weight: 600;
                }

                .pagination li a:hover {
                    background: var(--primary-pale);
                    color: var(--primary-dark);
                }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 3rem 2rem;
            color: var(--text-muted);
        }

            .empty-state i {
                font-size: 4rem;
                color: var(--primary-light);
                margin-bottom: 1rem;
            }

            .empty-state h3 {
                font-size: 1.5rem;
                color: var(--text-main);
                margin-bottom: 0.5rem;
            }

            .empty-state p {
                max-width: 500px;
                margin: 0 auto 1.5rem;
                font-size: 0.95rem;
            }

        /* Alerts */
        .alert {
            padding: 1rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .alert-success {
            background: rgba(45, 164, 78, 0.15);
            color: #2da44e;
            border: 1px solid rgba(45, 164, 78, 0.2);
        }

        .alert-error {
            background: rgba(192, 57, 43, 0.15);
            color: #c0392b;
            border: 1px solid rgba(192, 57, 43, 0.2);
        }

        /* Modal */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            padding: 1rem;
        }

        .modal-content {
            background: white;
            border-radius: 16px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
        }

        .modal-header {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .modal-header h3 {
                margin: 0;
                font-size: 1.3rem;
                color: var(--text-main);
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }

        .modal-close {
            font-size: 1.5rem;
            color: var(--text-dim);
            cursor: pointer;
            transition: var(--transition);
        }

            .modal-close:hover {
                color: var(--text-main);
            }

        .modal-body {
            padding: 1.5rem;
        }

            .modal-body p {
                margin: 0 0 1rem;
                font-size: 1rem;
                color: var(--text-main);
            }

        .warning-text {
            background: rgba(201, 150, 59, 0.1);
            border-left: 3px solid var(--accent);
            padding: 1rem;
            border-radius: 4px;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .modal-footer {
            padding: 1rem 1.5rem 1.5rem;
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
        }

        .btn-secondary {
            background: var(--bg-surface);
            color: var(--text-main);
            padding: 0.7rem 1.2rem;
            border-radius: 12px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: var(--transition);
        }

            .btn-secondary:hover {
                background: var(--primary-pale);
                color: var(--primary-dark);
            }

        .btn-danger {
            background: var(--error);
            color: white;
            padding: 0.7rem 1.2rem;
            border-radius: 12px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .btn-danger:hover {
                background: #a93226;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(192, 57, 43, 0.2);
            }

        /* Responsive Design */
        @@media (max-width: 1024px) {
            .admin-container {
                padding: 1.5rem;
            }
            
            .input-icon {
                width: 250px;
            }
        }

        @@media (max-width: 768px) {
            .admin-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .admin-actions {
                width: 100%;
            }
            
            .input-icon {
                width: 100%;
            }
            
            .admin-table {
                min-width: 800px;
            }
        }

        @@media (max-width: 480px) {
            .admin-container {
                padding: 1rem;
            }
            
            .card-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .header-info {
                width: 100%;
                justify-content: space-between;
            }
            
            .admin-table th, .admin-table td {
                padding: 0.8rem;
            }
            
            .category-actions {
                gap: 0.5rem;
            }
            
            .action-btn {
                width: 32px;
                height: 32px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Delete modal functionality
            const deleteButtons = document.querySelectorAll('.action-btn.delete');
            const deleteModal = document.getElementById('deleteModal');
            const modalClose = document.querySelector('.modal-close');
            const modalCloseBtn = document.querySelector('.modal-close-btn');
            const categoryNameSpan = document.getElementById('categoryName');
            const categoryIdInput = document.getElementById('categoryIdToDelete');
            
            // Open delete modal
            deleteButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const categoryId = this.getAttribute('data-category-id');
                    const categoryName = this.getAttribute('data-category-name');
                    
                    categoryNameSpan.textContent = categoryName;
                    categoryIdInput.value = categoryId;
                    deleteModal.style.display = 'flex';
                });
            });
            
            // Close modal functions
            function closeModal() {
                deleteModal.style.display = 'none';
            }
            
            modalClose.addEventListener('click', closeModal);
            modalCloseBtn.addEventListener('click', closeModal);
            
            // Close modal when clicking outside
            window.addEventListener('click', function(event) {
                if (event.target === deleteModal) {
                    closeModal();
                }
            });
            
            // Form submission feedback
            const deleteForm = document.getElementById('deleteForm');
            if (deleteForm) {
                deleteForm.addEventListener('submit', function() {
                    const submitButton = this.querySelector('button[type="submit"]');
                    const originalText = submitButton.innerHTML;
                    
                    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';
                    submitButton.disabled = true;
                });
            }
        });
    </script>
}

