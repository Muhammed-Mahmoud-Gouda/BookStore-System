@model ShopNest.BLL.DTOs.Category.CategoryResultDto
@{
    ViewData["Title"] = "Category Details - BookStore Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 800px; margin: 2rem auto; padding: 0 5%;">
    <div style="display: flex; gap: 0.8rem; align-items: center; margin-bottom: 2rem;">
        <a href="@Url.Action("Index", "Category")" style="color: var(--text-dim);"><i class="fas fa-arrow-left"></i> Back to Categories</a>
    </div>

    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2.5rem; box-shadow: var(--shadow-sm);">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid var(--primary-pale); padding-bottom: 1.2rem; margin-bottom: 2rem;">
            <h2 style="font-size: 1.6rem; font-weight: 800; color: var(--primary); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-layer-group"></i> Category: @Model.Name
            </h2>
            <a href="@Url.Action("Edit", "Category", new { id = Model.Id })" class="btn-primary-sm" style="font-size: 0.85rem; border-radius: 8px; padding: 0.5rem 1rem;">
                <i class="fas fa-edit"></i> Edit Details
            </a>
        </div>

        <div style="display: grid; grid-template-columns: 150px 1fr; gap: 2rem; align-items: start; margin-bottom: 2rem;">
            <div style="width: 150px; height: 150px; border-radius: 12px; border: 1.5px solid var(--border-color); overflow: hidden; background: #faf8f3; display: flex; align-items: center; justify-content: center; padding: 0.5rem;">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@Model.Name">
                }
                else
                {
                    <i class="fas fa-image" style="font-size: 3rem; color: var(--text-dim);"></i>
                }
            </div>

            <div>
                <h4 style="font-size: 0.9rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.4rem;">Description</h4>
                <p style="color: var(--text-main); font-size: 1rem; line-height: 1.6; margin-bottom: 1.5rem; white-space: pre-line;">
                    @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this category." : Model.Description)
                </p>

                <div style="display: flex; gap: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
                    <div>
                        <h5 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Total Books</h5>
                        <span class="badge" style="font-size: 0.9rem; padding: 0.4rem 1rem;">@Model.ProductsCount Books</span>
                    </div>

                    <div>
                        <h5 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Status</h5>
                        @if (Model.IsActive)
                        {
                            <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #2da44e; font-weight: 700; font-size: 0.95rem;">
                                <i class="fas fa-check-circle"></i> Active & Public
                            </span>
                        }
                        else
                        {
                            <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #d35400; font-weight: 700; font-size: 0.95rem;">
                                <i class="fas fa-times-circle"></i> Inactive & Hidden
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
