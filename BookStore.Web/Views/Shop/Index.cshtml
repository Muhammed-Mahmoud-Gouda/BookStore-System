@model List<ShopNest.BLL.DTOs.Product.ProductResultDto>
@using ShopNest.BLL.DTOs.Category
@{
    ViewData["Title"] = "Explore Books - BookStore";
    var categories = ViewBag.Categories as List<CategoryResultDto> ?? new List<CategoryResultDto>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/books.css" />
    <style>
        .shop-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 2.5rem;
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem 5%;
        }

        /* Sidebar styling */
        .shop-sidebar {
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            padding: 1.8rem;
            height: fit-content;
            box-shadow: var(--shadow-sm);
        }

        .filter-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 1.2rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--primary-pale);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .category-list {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .category-item-link {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.6rem 0.8rem;
            border-radius: 8px;
            color: var(--text-muted);
            font-size: 0.95rem;
            font-weight: 500;
            transition: var(--transition);
        }

        .category-item-link:hover, .category-item-link.active {
            background: var(--primary-pale);
            color: var(--primary);
            font-weight: 600;
        }

        .category-item-link .count-badge {
            background: var(--primary-light);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
        }

        /* Top Bar Styling */
        .shop-topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            padding: 1rem 1.8rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow-sm);
            flex-wrap: wrap;
            gap: 1rem;
        }

        .results-count {
            font-size: 0.95rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .results-count strong {
            color: var(--primary);
        }

        .shop-controls {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .sort-select {
            padding: 0.5rem 1rem;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--border-color);
            outline: none;
            background: white;
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.9rem;
            transition: var(--transition);
            cursor: pointer;
        }

        .sort-select:focus {
            border-color: var(--primary);
        }

        /* Shop Grid */
        .shop-main-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 2rem;
        }

        /* Responsive Layout */
        @@media (max-width: 1024px) {
            .shop-layout {
                grid-template-columns: 1fr;
            }
            .shop-sidebar {
                display: none; /* Hide sidebar on mobile, let them use search and dropdown filter if added */
            }
        }
    </style>
}

<div class="shop-layout">
    <!-- Sidebar / Filters -->
    <aside class="shop-sidebar">
        <h3 class="filter-title"><i class="fas fa-layer-group"></i> Categories</h3>
        <div class="category-list">
            <a href="@Url.Action("Index", "Shop", new { q = ViewBag.SearchQuery, sortBy = ViewBag.SelectedSortBy })" 
               class="category-item-link @(ViewBag.SelectedCategoryId == null ? "active" : "")">
                <span>All Categories</span>
                <span class="count-badge">@categories.Sum(c => c.ProductsCount)</span>
            </a>
            @foreach (var cat in categories)
            {
                <a href="@Url.Action("Index", "Shop", new { categoryId = cat.Id, q = ViewBag.SearchQuery, sortBy = ViewBag.SelectedSortBy })" 
                   class="category-item-link @(ViewBag.SelectedCategoryId == cat.Id ? "active" : "")">
                    <span>@cat.Name</span>
                    <span class="count-badge">@cat.ProductsCount</span>
                </a>
            }
        </div>
    </aside>

    <!-- Main Shop Area -->
    <section class="shop-content-area">
        <!-- Top Toolbar -->
        <div class="shop-topbar">
            <div class="results-count">
                Showing <strong>@Model.Count</strong> of <strong>@ViewBag.TotalCount</strong> tech books under <em>"@ViewBag.SelectedCategoryName"</em>
            </div>
            
            <div class="shop-controls">
                <form method="get" asp-action="Index" class="search-container" style="display: flex; width: auto; min-width: 250px; background: #faf8f3; border-radius: 50px; border: 1.5px solid var(--border-color); padding: 0.4rem 1rem;">
                    @if (ViewBag.SelectedCategoryId != null)
                    {
                        <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategoryId" />
                    }
                    @if (ViewBag.SelectedSortBy != null)
                    {
                        <input type="hidden" name="sortBy" value="@ViewBag.SelectedSortBy" />
                    }
                    <i class="fas fa-search" style="color: var(--text-dim); margin-top: 0.3rem;"></i>
                    <input type="text" name="q" value="@ViewBag.SearchQuery" placeholder="Search this catalog..." style="border: none; background: transparent; outline: none; margin-left: 0.5rem; font-size: 0.85rem; width: 100%;">
                </form>

                <div class="sort-wrapper">
                    <select class="sort-select" id="sortBySelect" onchange="applySorting(this.value)">
                        <option value="name" selected="@(ViewBag.SelectedSortBy == "name" || ViewBag.SelectedSortBy == null)">Sort Alphabetical</option>
                        <option value="newest" selected="@(ViewBag.SelectedSortBy == "newest")">New Arrivals</option>
                        <option value="price_asc" selected="@(ViewBag.SelectedSortBy == "price_asc")">Price: Low to High</option>
                        <option value="price_desc" selected="@(ViewBag.SelectedSortBy == "price_desc")">Price: High to Low</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Books Grid -->
        @if (Model.Any())
        {
            <div class="shop-main-grid">
                @foreach (var book in Model)
                {
                    <div class="book-card" style="margin: 0; background: white; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); border-radius: var(--radius-md); overflow: hidden;">
                        <div class="book-cover-wrap" style="height: 320px; overflow: hidden; background: #fdfdfd; display: flex; align-items: center; justify-content: center; position: relative;">
                            @if (book.Price < 300)
                            {
                                <span class="book-badge" style="background: var(--accent); color: white; position: absolute; top: 12px; left: 12px; padding: 4px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 700; z-index: 10;">Hot Deal</span>
                            }
                            <img src="@(string.IsNullOrEmpty(book.MainImagePath) ? "/images/default-book.png" : book.MainImagePath)" 
                                 alt="@book.Name" 
                                 style="max-height: 85%; max-width: 80%; object-fit: contain; box-shadow: 0 8px 16px rgba(0,0,0,0.15);"
                                 onerror="this.src='/images/default-book.png'">
                            <div class="book-actions">
                                <a href="@Url.Action("Details", "Shop", new { id = book.Id })" class="action-btn view-btn" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <button class="action-btn cart-btn" title="Add to Cart" data-book-id="@book.Id">
                                    <i class="fas fa-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                        <div style="padding: 1.2rem;">
                            <div class="book-meta" style="font-size: 0.8rem; text-transform: uppercase; color: var(--accent); font-weight: 700; margin-bottom: 0.4rem;">@book.CategoryName</div>
                            <h3 class="book-name" style="font-size: 1.05rem; font-weight: 700; color: var(--text-main); margin-bottom: 0.3rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@book.Name</h3>
                            <p class="book-author" style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.8rem;">by @(book.Author ?? "Unknown")</p>
                            <div class="book-footer" style="display: flex; justify-content: space-between; align-items: center;">
                                <span class="book-price" style="font-size: 1.15rem; font-weight: 800; color: var(--primary);">EGP @book.Price.ToString("N0")</span>
                                <div class="book-rating" style="display: flex; align-items: center; gap: 0.3rem; color: var(--accent); font-size: 0.85rem;">
                                    <i class="fas fa-star"></i>
                                    <span style="font-weight: 700; color: var(--text-main);">4.8</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="pagination-container" style="display: flex; justify-content: center; margin-top: 3rem;">
                    <ul class="pagination" style="display: flex; list-style: none; gap: 0.5rem; padding: 0;">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="@(i == ViewBag.CurrentPage ? "active" : "")">
                                <a href="@Url.Action("Index", new { categoryId = ViewBag.SelectedCategoryId, q = ViewBag.SearchQuery, sortBy = ViewBag.SelectedSortBy, page = i })"
                                   style="display: flex; align-items: center; justify-content: center; width: 42px; height: 42px; border-radius: 10px; background: @(i == ViewBag.CurrentPage ? "var(--primary)" : "white"); color: @(i == ViewBag.CurrentPage ? "white" : "var(--text-muted)"); border: 1px solid var(--border-color); font-weight: 700; transition: var(--transition);">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="background: white; border: 1px solid var(--border-color); padding: 4rem 2rem; border-radius: var(--radius-md); text-align: center; margin-top: 2rem;">
                <i class="fas fa-book-open" style="font-size: 4rem; color: var(--primary-light); margin-bottom: 1.5rem;"></i>
                <h3 style="font-size: 1.5rem; color: var(--text-main); margin-bottom: 0.5rem;">No Books Found</h3>
                <p style="color: var(--text-muted); max-width: 500px; margin: 0 auto 1.5rem;">We couldn't find any technical books that match your filters or search query. Try broadening your terms or checking other categories!</p>
                <a href="@Url.Action("Index", "Shop")" class="btn-primary-sm" style="display: inline-flex; width: auto; margin: 0 auto; text-decoration: none;">Clear All Filters</a>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        function applySorting(val) {
            const urlParams = new URLSearchParams(window.location.search);
            urlParams.set('sortBy', val);
            urlParams.set('page', '1');
            window.location.search = urlParams.toString();
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Cart button trigger (shared logic is in Layout/Main page, but we ensure it registers toast)
            document.querySelectorAll('.cart-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const bookId = this.dataset.bookId;
                    this.classList.add('clicked');
                    setTimeout(() => this.classList.remove('clicked'), 300);
                    
                    // Call add to cart endpoint
                    addToCart(bookId);
                });
            });
        });

        function addToCart(productId) {
            fetch(`/Cart/Add/${productId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    showToast('Added to cart successfully! 🛒');
                    // Update badges
                    document.querySelectorAll('.badge').forEach(badge => {
                        badge.textContent = data.cartCount;
                    });
                } else {
                    showToast('Failed to add book to cart: ' + data.message);
                }
            })
            .catch(err => {
                console.error(err);
                showToast('Failed to add book to cart.');
            });
        }

        function showToast(message) {
            let toast = document.getElementById('toast-notification');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast-notification';
                toast.className = 'toast-notification';
                document.body.appendChild(toast);
            }
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }
    </script>

    <!-- Toast Notification styles -->
    <style>
        .toast-notification {
            position: fixed;
            bottom: 24px;
            right: 24px;
            background: var(--primary);
            color: white;
            padding: 14px 24px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            font-weight: 600;
            z-index: 9999;
            transform: translateX(150%);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .toast-notification.show {
            transform: translateX(0);
        }
        .cart-btn.clicked {
            animation: pulse 0.3s ease;
        }
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.15); }
            100% { transform: scale(1); }
        }
    </style>
}
