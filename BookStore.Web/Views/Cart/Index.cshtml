@model List<ShopNest.Web.Controllers.CartItem>
@{
    ViewData["Title"] = "Shopping Cart - BookStore";
}

@section Styles {
    <style>
        .cart-wrapper {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 5%;
        }

        .cart-title {
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            gap: 0.8rem;
        }

        .cart-grid {
            display: grid;
            grid-template-columns: 1.8fr 1fr;
            gap: 3rem;
            align-items: start;
        }

        /* Cart items table */
        .cart-panel {
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            padding: 2rem;
            box-shadow: var(--shadow-sm);
        }

        .cart-table {
            width: 100%;
            border-collapse: collapse;
        }

        .cart-table th {
            text-align: left;
            padding-bottom: 1rem;
            border-bottom: 2px solid var(--primary-pale);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.9rem;
        }

        .cart-table td {
            padding: 1.5rem 0;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }

        .cart-table tr:last-child td {
            border-bottom: none;
        }

        .cart-item-info {
            display: flex;
            align-items: center;
            gap: 1.2rem;
        }

        .cart-item-img {
            width: 70px;
            height: 90px;
            background: #faf8f3;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0.5rem;
        }

        .cart-item-img img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .cart-item-details h4 {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.2rem;
        }

        .cart-item-details p {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .cart-qty-picker {
            display: flex;
            align-items: center;
            border: 1.5px solid var(--border-color);
            border-radius: var(--radius-sm);
            width: fit-content;
            background: white;
        }

        .cart-qty-btn {
            border: none;
            background: none;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-weight: 700;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .cart-qty-btn:hover {
            background: var(--primary-pale);
            color: var(--primary);
        }

        .cart-qty-input {
            width: 36px;
            height: 32px;
            border: none;
            border-left: 1.5px solid var(--border-color);
            border-right: 1.5px solid var(--border-color);
            text-align: center;
            outline: none;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-main);
        }

        .remove-btn {
            color: var(--error);
            border: none;
            background: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            transition: var(--transition);
        }

        .remove-btn:hover {
            opacity: 0.8;
            transform: scale(1.05);
        }

        /* Order Summary Panel */
        .summary-panel {
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            padding: 2rem;
            box-shadow: var(--shadow-sm);
            height: fit-content;
        }

        .summary-title {
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 1.5rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--primary-pale);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            font-size: 0.95rem;
            color: var(--text-muted);
        }

        .summary-row.total-row {
            border-top: 1px dashed var(--border-color);
            padding-top: 1rem;
            margin-top: 1.5rem;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--primary);
        }

        .btn-checkout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            background: var(--accent);
            color: white;
            padding: 0.85rem;
            border-radius: var(--radius-sm);
            font-weight: 700;
            border: none;
            cursor: pointer;
            width: 100%;
            transition: var(--transition);
            margin-top: 1.5rem;
            text-transform: uppercase;
            box-shadow: 0 4px 12px rgba(201, 150, 59, 0.2);
            text-decoration: none;
            font-size: 0.95rem;
        }

        .btn-checkout:hover {
            background: #b5802a;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(201, 150, 59, 0.3);
        }

        @@media (max-width: 900px) {
            .cart-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
        }
    </style>
}

<div class="cart-wrapper">
    <h2 class="cart-title"><i class="fas fa-shopping-cart"></i> Your Shopping Cart</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error" style="background: rgba(192,57,43,0.12); color: var(--error); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    @if (Model.Any())
    {
        <div class="cart-grid">
            <!-- Table of Items -->
            <div class="cart-panel">
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Book Details</th>
                            <th>Quantity</th>
                            <th style="text-align: right;">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.ProductId">
                                <td>
                                    <div class="cart-item-info">
                                        <div class="cart-item-img">
                                            <img src="@item.MainImagePath" alt="@item.BookName" onerror="this.src='/images/default-book.png'">
                                        </div>
                                        <div class="cart-item-details">
                                            <h4>@item.BookName</h4>
                                            <p>by @item.Author</p>
                                            <p style="font-weight: 700; color: var(--primary); margin-top: 0.2rem;">EGP @item.Price.ToString("N0")</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="cart-qty-picker">
                                        <button type="button" class="cart-qty-btn" onclick="modifyQty(@item.ProductId, -1)">-</button>
                                        <input type="text" id="qty-@item.ProductId" class="cart-qty-input" value="@item.Quantity" readonly>
                                        <button type="button" class="cart-qty-btn" onclick="modifyQty(@item.ProductId, 1)">+</button>
                                    </div>
                                </td>
                                <td style="text-align: right; font-weight: 800; color: var(--text-main);" id="subtotal-@item.ProductId">
                                    EGP @item.Total.ToString("N0")
                                </td>
                                <td style="width: 80px; text-align: center;">
                                    <form method="post" asp-action="Remove" asp-controller="Cart" asp-route-id="@item.ProductId">
                                        <button type="submit" class="remove-btn">
                                            <i class="fas fa-trash-alt"></i> Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Summary Sidebar -->
            <div class="summary-panel">
                <h3 class="summary-title">Order Summary</h3>
                <div class="summary-row">
                    <span>Items Count</span>
                    <span id="summaryCount">@Model.Sum(i => i.Quantity) items</span>
                </div>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span id="summarySubtotal">EGP @Model.Sum(i => i.Total).ToString("N0")</span>
                </div>
                <div class="summary-row">
                    <span>Shipping (Cairo / Giza)</span>
                    <span style="color: #2da44e; font-weight: 700;">FREE</span>
                </div>

                <div class="summary-row total-row">
                    <span>Total Amount</span>
                    <span id="summaryTotal">EGP @Model.Sum(i => i.Total).ToString("N0")</span>
                </div>

                <a href="@Url.Action("Checkout", "Cart")" class="btn-checkout">
                    <i class="fas fa-credit-card"></i> Proceed to Checkout
                </a>
                
                <a href="@Url.Action("Index", "Shop")" style="display: block; text-align: center; color: var(--primary); font-weight: 700; margin-top: 1rem; font-size: 0.9rem;">
                    <i class="fas fa-arrow-left"></i> Continue Shopping
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state" style="background: white; border: 1px solid var(--border-color); padding: 5rem 2rem; border-radius: var(--radius-md); text-align: center;">
            <i class="fas fa-shopping-basket" style="font-size: 5rem; color: var(--primary-light); margin-bottom: 1.5rem; display: block;"></i>
            <h3 style="font-size: 1.6rem; color: var(--text-main); margin-bottom: 0.6rem;">Your Cart is Empty</h3>
            <p style="color: var(--text-muted); max-width: 500px; margin: 0 auto 2rem; font-size: 1rem;">Looks like you haven't added any technical literature to your shopping basket yet. Start exploring egypt's finest tech bookstore catalog now!</p>
            <a href="@Url.Action("Index", "Shop")" class="btn-checkout" style="display: inline-flex; width: auto; padding: 0.8rem 2.5rem; margin: 0 auto;">Browse Book Store</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function modifyQty(productId, change) {
            const input = document.getElementById(`qty-${productId}`);
            let current = parseInt(input.value);
            current += change;
            if (current < 1) current = 1;
            
            input.value = current;

            // Submit Ajax
            fetch(`/Cart/UpdateQuantity?productId=${productId}&qty=${current}`, {
                method: 'POST'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // Update subtotal
                    document.getElementById(`subtotal-${productId}`).textContent = 'EGP ' + data.itemSubtotal;
                    // Update summaries
                    document.getElementById('summaryCount').textContent = data.cartCount + ' items';
                    document.getElementById('summarySubtotal').textContent = 'EGP ' + data.cartTotal;
                    document.getElementById('summaryTotal').textContent = 'EGP ' + data.cartTotal;
                    
                    // Update badges
                    document.querySelectorAll('.btn-icon .badge').forEach(badge => {
                        badge.textContent = data.cartCount;
                    });
                }
            })
            .catch(err => console.error(err));
        }
    </script>
}
