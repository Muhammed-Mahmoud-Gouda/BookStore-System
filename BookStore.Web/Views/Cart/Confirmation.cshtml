@{
    ViewData["Title"] = "Order Confirmed - ShopNest";
}

<div style="max-width: 600px; margin: 4rem auto; padding: 0 5%; text-align: center;">
    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 4rem 2rem; box-shadow: var(--shadow-sm);">
        <div style="width: 80px; height: 80px; background: rgba(45, 164, 78, 0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #2da44e; font-size: 2.5rem; margin: 0 auto 2rem;">
            <i class="fas fa-check-circle"></i>
        </div>

        <h1 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 0.8rem;">Order Placed Successfully!</h1>
        <p style="color: var(--text-muted); font-size: 1.05rem; line-height: 1.6; margin-bottom: 2.5rem;">
            Thank you for shopping at BookStore! Your order has been registered in our system. We are preparing your tech books and our courier will contact you shortly for cash-on-delivery.
        </p>

        <div style="background: var(--primary-pale); border-radius: 12px; border: 1.5px solid var(--primary-light); padding: 1.5rem; text-align: left; margin-bottom: 3rem;">
            <h4 style="font-size: 1rem; font-weight: 700; color: var(--primary); margin-bottom: 0.6rem;"><i class="fas fa-truck"></i> What happens next?</h4>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; font-size: 0.9rem; color: var(--text-muted);">
                <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
                    <i class="fas fa-envelope" style="color: var(--primary); margin-top: 0.2rem;"></i>
                    <span>An order invoice has been sent to your email.</span>
                </li>
                <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
                    <i class="fas fa-phone-alt" style="color: var(--primary); margin-top: 0.2rem;"></i>
                    <span>Our Cairo logistics team will call or text to confirm delivery details.</span>
                </li>
                <li style="display: flex; gap: 0.5rem; align-items: flex-start;">
                    <i class="fas fa-shipping-fast" style="color: var(--primary); margin-top: 0.2rem;"></i>
                    <span>Delivery takes 24 hours within Cairo and Giza, and 2-3 days other cities.</span>
                </li>
            </ul>
        </div>

        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="@Url.Action("Index", "Shop")" class="btn-primary-sm" style="flex: 1; padding: 0.85rem; justify-content: center; text-decoration: none; border-radius: 8px;">
                <i class="fas fa-book-open"></i> Continue Shopping
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn-primary-sm" style="flex: 1; padding: 0.85rem; justify-content: center; text-decoration: none; border-radius: 8px; background: white; color: var(--primary); border: 1.5px solid var(--primary);">
                <i class="fas fa-home"></i> Back to Home
            </a>
        </div>
    </div>
</div>
