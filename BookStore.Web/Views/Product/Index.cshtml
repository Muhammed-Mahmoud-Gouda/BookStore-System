@model ShopNest.Web.ViewModels.Product.ProductIndexViewModel
@{
    ViewData["Title"] = "Products Management - BookStore Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 1400px; margin: 0 auto; padding: 2rem 5%;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h1 style="font-size: 1.8rem; color: var(--primary); display: flex; align-items: center; gap: 0.75rem; font-weight: 800;">
            <i class="fas fa-book"></i> Book Catalog Management
        </h1>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
            <form method="get" class="search-form" asp-action="Index" style="display: flex; gap: 0.8rem; align-items: center;">
                <div class="input-icon" style="position: relative; width: 260px;">
                    <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-dim);"></i>
                    <input type="text" name="searchTerm" placeholder="Search books..." value="@Model.SearchTerm" style="width: 100%; padding: 0.65rem 1rem 0.65rem 2.5rem; border: 1.5px solid var(--border-color); border-radius: 50px; outline: none; font-size: 0.9rem;">
                </div>
                <select name="categoryId" asp-items="Model.Categories" style="padding: 0.65rem 1rem; border-radius: 50px; border: 1.5px solid var(--border-color); outline: none; font-weight: 600; color: var(--text-muted); cursor: pointer; font-size: 0.88rem;">
                    <option value="">All Categories</option>
                </select>
                <button type="submit" class="btn-primary-sm" style="border-radius: 50px; padding: 0.65rem 1.2rem; font-weight: 700;">Filter</button>
            </form>
            <a href="@Url.Action("Create", "Product")" class="btn-primary-sm" style="border-radius: 50px; padding: 0.65rem 1.4rem; font-weight: 700;">
                <i class="fas fa-plus-circle"></i> Add New Book
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" style="background: rgba(45, 164, 78, 0.12); color: #2da44e; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(45, 164, 78, 0.15);">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error" style="background: rgba(192,57,43,0.12); color: var(--error); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(192, 57, 43, 0.15);">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <div style="background: white; border-radius: 20px; box-shadow: var(--shadow-sm); border: 1px solid var(--border-color); overflow: hidden;">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); background: var(--primary-pale); display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-size: 1.2rem; font-weight: 800; color: var(--primary); margin: 0;">Catalog List</h2>
            <span class="badge" style="font-size: 0.85rem; padding: 0.35rem 0.8rem;">@Model.TotalCount Books</span>
        </div>

        <div style="padding: 1.5rem;">
            @if (Model.Products.Any())
            {
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--border-color);">
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Cover</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Book Details</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Category</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Price</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Stock</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem;">Status</th>
                                <th style="padding: 1rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem; text-align: right;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in Model.Products)
                            {
                                <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='#faf8f3'" onmouseout="this.style.background='white'">
                                    <td style="padding: 1rem;">
                                        <div style="width: 50px; height: 65px; border-radius: 4px; border: 1px solid var(--border-color); overflow: hidden; background: #faf8f3; display: flex; align-items: center; justify-content: center; padding: 0.2rem;">
                                            <img src="@(string.IsNullOrEmpty(book.MainImagePath) ? "/images/default-book.png" : book.MainImagePath)" style="max-height: 100%; max-width: 100%; object-fit: contain;" onerror="this.src='/images/default-book.png'">
                                        </div>
                                    </td>
                                    <td style="padding: 1rem;">
                                        <div style="font-weight: 700; color: var(--text-main); font-size: 0.98rem; max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@book.Name">
                                            @book.Name
                                        </div>
                                        <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.1rem;">
                                            by @(book.Author ?? "Unknown") | ISBN: @(book.ISBN ?? "N/A")
                                        </div>
                                    </td>
                                    <td style="padding: 1rem; color: var(--text-muted); font-weight: 600;">
                                        @book.CategoryName
                                    </td>
                                    <td style="padding: 1rem; font-weight: 800; color: var(--primary);">
                                        EGP @book.Price.ToString("N0")
                                    </td>
                                    <td style="padding: 1rem;">
                                        @if (book.Stock == 0)
                                        {
                                            <span style="color: var(--error); font-weight: 700;">OUT OF STOCK</span>
                                        }
                                        else if (book.Stock <= 5)
                                        {
                                            <span style="color: #e67e22; font-weight: 700;">Low Stock (@book.Stock)</span>
                                        }
                                        else
                                        {
                                            <span style="color: var(--text-main); font-weight: 600;">@book.Stock units</span>
                                        }
                                    </td>
                                    <td style="padding: 1rem;">
                                        @if (book.IsActive)
                                        {
                                            <span style="background: rgba(45,164,78,0.12); color: #2da44e; padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: 700;"><i class="fas fa-check-circle"></i> Active</span>
                                        }
                                        else
                                        {
                                            <span style="background: rgba(192,57,43,0.12); color: var(--error); padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: 700;"><i class="fas fa-times-circle"></i> Inactive</span>
                                        }
                                    </td>
                                    <td style="padding: 1rem; text-align: right;">
                                        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                            <a href="@Url.Action("Edit", "Product", new { id = book.Id })" style="width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; color: var(--primary); background: white; transition: all 0.2s;" onmouseover="this.style.background='var(--primary-pale)'" onmouseout="this.style.background='white'">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="@Url.Action("Details", "Product", new { id = book.Id })" style="width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; color: var(--accent); background: white; transition: all 0.2s;" onmouseover="this.style.background='var(--accent-light)'" onmouseout="this.style.background='white'">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <button type="button" onclick="confirmDelete(@book.Id, '@Html.Raw("JavaScriptEncoder.Default.Encode(book.Name))")" style="width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border-color); display: flex; align-items: center; justify-content: center; color: var(--error); background: white; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='rgba(192,57,43,0.08)'" onmouseout="this.style.background='white'">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div style="display: flex; justify-content: center; margin-top: 2rem;">
                        <ul style="display: flex; list-style: none; gap: 0.5rem; padding: 0;">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="@(i == Model.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action("Index", new { searchTerm = Model.SearchTerm, categoryId = Model.CategoryId, page = i })"
                                       style="display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 8px; background: @(i == Model.CurrentPage ? "var(--primary)" : "white"); color: @(i == Model.CurrentPage ? "white" : "var(--text-muted)"); border: 1px solid var(--border-color); font-weight: 700; transition: var(--transition); text-decoration: none;">
                                        @i
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
            else
            {
                <div style="text-align: center; padding: 4rem 2rem; color: var(--text-muted);">
                    <i class="fas fa-book-open" style="font-size: 4.5rem; color: var(--primary-light); margin-bottom: 1.5rem; display: block;"></i>
                    <h3 style="font-size: 1.5rem; color: var(--text-main); margin-bottom: 0.5rem;">No Books Found</h3>
                    <p style="max-width: 500px; margin: 0 auto 1.5rem; font-size: 0.95rem;">We couldn't find any books matching your search filters in the catalog.</p>
                    <a href="@Url.Action("Create", "Product")" class="btn-primary-sm" style="display: inline-flex; width: auto; margin: 0 auto; text-decoration: none;">Add Your First Book</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal" id="deleteProductModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); align-items: center; justify-content: center; z-index: 9999;">
    <div style="background: white; border-radius: 16px; width: 100%; max-width: 500px; box-shadow: var(--shadow-lg); overflow: hidden;">
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0; font-size: 1.25rem; color: var(--text-main); display: flex; align-items: center; gap: 0.5rem;"><i class="fas fa-exclamation-triangle" style="color: var(--error);"></i> Confirm Deletion</h3>
            <span onclick="closeDeleteModal()" style="font-size: 1.5rem; color: var(--text-dim); cursor: pointer;">&times;</span>
        </div>
        <div style="padding: 1.5rem;">
            <p style="margin: 0 0 1rem; font-size: 1rem; color: var(--text-main);">Are you sure you want to delete the book <strong id="deleteProductName"></strong>?</p>
            <p style="background: rgba(192,57,43,0.08); border-left: 3px solid var(--error); padding: 0.8rem; border-radius: 4px; font-size: 0.85rem; color: var(--error); font-weight: 600; margin: 0;">
                Warning: This action is permanent and cannot be undone.
            </p>
        </div>
        <div style="padding: 1rem 1.5rem 1.5rem; display: flex; justify-content: flex-end; gap: 1rem;">
            <button type="button" onclick="closeDeleteModal()" style="background: var(--bg-surface); border: 1.5px solid var(--border-color); color: var(--text-muted); padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 700; cursor: pointer;">Cancel</button>
            <form id="deleteProductForm" method="post" action="@Url.Action("DeleteConfirmed", "Product")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteProductId">
                <button type="submit" style="background: var(--error); color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 8px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
                    <i class="fas fa-trash-alt"></i> Delete Book
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, name) {
            document.getElementById('deleteProductId').value = id;
            document.getElementById('deleteProductName').textContent = name;
            
            const form = document.getElementById('deleteProductForm');
            form.action = `/Product/Delete/${id}`;
            
            document.getElementById('deleteProductModal').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteProductModal').style.display = 'none';
        }
    </script>
}
