@model ShopNest.BLL.DTOs.Product.ProductResultDto
@{
    ViewData["Title"] = $"Book Details: {Model.Name} - BookStore Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 900px; margin: 2rem auto; padding: 0 5%;">
    <div style="display: flex; gap: 0.8rem; align-items: center; margin-bottom: 2rem;">
        <a href="@Url.Action("Index", "Product")" style="color: var(--text-dim);"><i class="fas fa-arrow-left"></i> Back to Book Catalog</a>
    </div>

    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2.5rem; box-shadow: var(--shadow-sm);">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid var(--primary-pale); padding-bottom: 1.2rem; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 1.6rem; font-weight: 800; color: var(--primary); margin: 0;">
                    <i class="fas fa-book"></i> @Model.Name
                </h2>
                <p style="color: var(--text-muted); font-size: 0.95rem; margin-top: 0.2rem;">by @(Model.Author ?? "Unknown Author")</p>
            </div>
            <a href="@Url.Action("Edit", "Product", new { id = Model.Id })" class="btn-primary-sm" style="font-size: 0.85rem; border-radius: 8px; padding: 0.5rem 1rem;">
                <i class="fas fa-edit"></i> Edit Book
            </a>
        </div>

        <div style="display: grid; grid-template-columns: 200px 1fr; gap: 2.5rem; align-items: start; margin-bottom: 3rem;">
            <!-- Cover wrap -->
            <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div style="width: 200px; height: 260px; border-radius: 12px; border: 1.5px solid var(--border-color); overflow: hidden; background: #faf8f3; display: flex; align-items: center; justify-content: center; padding: 0.5rem; box-shadow: 0 8px 16px rgba(0,0,0,0.06);">
                    <img src="@(string.IsNullOrEmpty(Model.MainImagePath) ? "/images/default-book.png" : Model.MainImagePath)" style="max-height: 100%; max-width: 100%; object-fit: contain; box-shadow: 0 4px 8px rgba(0,0,0,0.1);" alt="@Model.Name" onerror="this.src='/images/default-book.png'">
                </div>

                @if (Model.Images != null && Model.Images.Count > 1)
                {
                    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                        @foreach (var img in Model.Images)
                        {
                            <div style="width: 44px; height: 56px; border-radius: 4px; border: 1px solid var(--border-color); overflow: hidden; background: white; display: flex; align-items: center; justify-content: center; padding: 0.2rem;">
                                <img src="@img.ImagePath" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="Thumbnail">
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Details metadata -->
            <div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                    <div>
                        <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Catalog Category</h4>
                        <span class="badge" style="font-size: 0.88rem; padding: 0.35rem 0.8rem;">@Model.CategoryName</span>
                    </div>

                    <div>
                        <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Status</h4>
                        @if (Model.IsActive)
                        {
                            <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #2da44e; font-weight: 700; font-size: 0.95rem;">
                                <i class="fas fa-check-circle"></i> Active & Public
                            </span>
                        }
                        else
                        {
                            <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #d35400; font-weight: 700; font-size: 0.95rem;">
                                <i class="fas fa-times-circle"></i> Inactive & Hidden
                            </span>
                        }
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem; margin-bottom: 2rem;">
                    <div>
                        <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Price</h4>
                        <span style="font-size: 1.6rem; font-weight: 800; color: var(--primary);">EGP @Model.Price.ToString("N0")</span>
                    </div>

                    <div>
                        <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.2rem;">Stock Availability</h4>
                        @if (Model.Stock == 0)
                        {
                            <span style="color: var(--error); font-weight: 800; font-size: 1.2rem;">OUT OF STOCK</span>
                        }
                        else if (Model.Stock <= 5)
                        {
                            <span style="color: #e67e22; font-weight: 800; font-size: 1.2rem;">LOW STOCK (@Model.Stock)</span>
                        }
                        else
                        {
                            <span style="color: var(--text-main); font-weight: 700; font-size: 1.2rem;">@Model.Stock units</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Description overview -->
        <div style="margin-bottom: 3rem;">
            <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--primary); margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;"><i class="fas fa-info-circle"></i> Overview Description</h3>
            <p style="color: var(--text-muted); font-size: 0.98rem; line-height: 1.6; white-space: pre-line; margin: 0;">
                @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this catalog book." : Model.Description)
            </p>
        </div>

        <!-- Technical specs table -->
        <div>
            <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--primary); margin-bottom: 1rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem;"><i class="fas fa-microchip"></i> Specifications</h3>
            <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
                <tbody>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); width: 30%; background: #faf8f3;">ISBN-13</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(Model.ISBN ?? "N/A")</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Format</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@Model.Format.ToString()</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Language</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(Model.Language ?? "English")</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Pages Count</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(Model.Pages.HasValue ? Model.Pages.Value.ToString() : "N/A") pages</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Publisher</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(Model.Publisher ?? "N/A")</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Publication Year</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(Model.PublicationYear.HasValue ? Model.PublicationYear.Value.ToString() : "N/A")</td>
                    </tr>
                    <tr style="border-bottom: 1px solid var(--border-color);">
                        <td style="padding: 0.8rem 1rem; font-weight: 700; color: var(--text-muted); background: #faf8f3;">Edition</td>
                        <td style="padding: 0.8rem 1rem; color: var(--text-main); font-weight: 500;">@(string.IsNullOrEmpty(Model.Edition) ? "1st Edition" : Model.Edition)</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
