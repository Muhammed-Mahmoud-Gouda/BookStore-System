@model ShopNest.Web.ViewModels.Product.ProductCreateViewModel
@{
    ViewData["Title"] = "Add New Book - BookStore Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 900px; margin: 2rem auto; padding: 0 5%;">
    <div style="display: flex; gap: 0.8rem; align-items: center; margin-bottom: 2rem;">
        <a href="@Url.Action("Index", "Product")" style="color: var(--text-dim);"><i class="fas fa-arrow-left"></i> Back to Book Catalog</a>
    </div>

    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2.5rem; box-shadow: var(--shadow-sm);">
        <h2 style="font-size: 1.5rem; font-weight: 800; color: var(--primary); margin-bottom: 1.8rem; padding-bottom: 0.6rem; border-bottom: 2px solid var(--primary-pale); display: flex; align-items: center; gap: 0.5rem;">
            <i class="fas fa-plus-circle"></i> Add New Book to Catalog
        </h2>

        <form method="post" asp-action="Create" asp-controller="Product" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-error" style="background: rgba(192,57,43,0.12); color: var(--error); padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;"></div>

            <!-- Basic Info Section -->
            <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 1.2rem;"><i class="fas fa-info-circle"></i> Basic Information</h3>
                
                <div style="margin-bottom: 1.5rem;">
                    <label asp-for="Name">Book Title</label>
                    <input type="text" asp-for="Name" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. Designing Data-Intensive Applications" required>
                    <span asp-validation-for="Name" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                    <div>
                        <label asp-for="CategoryId">Category</label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem; background: white; cursor: pointer;" required>
                            <option value="">Select Category</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="Format">Book Format</label>
                        <select asp-for="Format" asp-items="Model.Formats" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem; background: white; cursor: pointer;" required>
                            <option value="">Select Format</option>
                        </select>
                        <span asp-validation-for="Format" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                </div>

                <div style="margin-bottom: 1.5rem;">
                    <label asp-for="Description">Overview Description</label>
                    <textarea asp-for="Description" rows="4" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem; resize: vertical;" placeholder="Write a short summary about the book's contents, target audience, and key concepts..."></textarea>
                    <span asp-validation-for="Description" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                </div>
            </div>

            <!-- Price & Stock Section -->
            <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 1.2rem;"><i class="fas fa-tags"></i> Pricing & Inventory</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label asp-for="Price">Price (EGP)</label>
                        <input type="number" asp-for="Price" step="1" min="1" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 350" required>
                        <span asp-validation-for="Price" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="Stock">Stock Count</label>
                        <input type="number" asp-for="Stock" min="0" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 50" required>
                        <span asp-validation-for="Stock" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                </div>
            </div>

            <!-- Book Specs Section -->
            <div style="margin-bottom: 2rem;">
                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 1.2rem;"><i class="fas fa-microchip"></i> Specifications</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                    <div>
                        <label asp-for="Author">Author</label>
                        <input type="text" asp-for="Author" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. Martin Kleppmann" required>
                        <span asp-validation-for="Author" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="Publisher">Publisher</label>
                        <input type="text" asp-for="Publisher" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. O'Reilly Media">
                        <span asp-validation-for="Publisher" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                    <div>
                        <label asp-for="ISBN">ISBN-13</label>
                        <input type="text" asp-for="ISBN" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 978-1449373320">
                        <span asp-validation-for="ISBN" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="PublicationYear">Publication Year</label>
                        <input type="number" asp-for="PublicationYear" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 2017">
                        <span asp-validation-for="PublicationYear" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
                    <div>
                        <label asp-for="Pages">Pages Count</label>
                        <input type="number" asp-for="Pages" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 611">
                        <span asp-validation-for="Pages" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="Language">Language</label>
                        <input type="text" asp-for="Language" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. English">
                        <span asp-validation-for="Language" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                    <div>
                        <label asp-for="Edition">Edition</label>
                        <input type="text" asp-for="Edition" style="width: 100%; padding: 0.75rem 1rem; border-radius: 8px; border: 1.5px solid var(--border-color); outline: none; font-size: 0.95rem;" placeholder="e.g. 1st Edition">
                        <span asp-validation-for="Edition" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    </div>
                </div>
            </div>

            <!-- Image Upload Section -->
            <div style="margin-bottom: 3rem;">
                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 1.2rem;"><i class="fas fa-images"></i> Product Gallery</h3>
                
                <div>
                    <label asp-for="Images">Upload Cover & Gallery Images</label>
                    <input type="file" asp-for="Images" style="width: 100%; padding: 0.6rem; border-radius: 8px; border: 1.5px dashed var(--border-color); background: var(--primary-pale); cursor: pointer;" accept="image/*" multiple>
                    <span asp-validation-for="Images" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                    <p style="font-size: 0.78rem; color: var(--text-dim); margin-top: 0.4rem;">You can select multiple images at once. The first image uploaded will act as the primary book cover.</p>
                </div>
            </div>

            <!-- Form actions -->
            <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border-color); padding-top: 2rem;">
                <button type="submit" class="btn-primary-sm" style="flex: 1; padding: 0.85rem; justify-content: center; border-radius: 8px; font-weight: 700;">
                    <i class="fas fa-check"></i> Add Book to Catalog
                </button>
                <a href="@Url.Action("Index", "Product")" class="btn-primary-sm" style="flex: 1; padding: 0.85rem; justify-content: center; text-decoration: none; border-radius: 8px; background: white; color: var(--text-muted); border: 1.5px solid var(--border-color);">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        form label {
            display: block;
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }
    </style>
}
