@model ShopNest.BLL.DTOs.Customer.CustomerResultDto
@{
    ViewData["Title"] = $"Customer Profile: {Model.FullName} - BookStore Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 1000px; margin: 2rem auto; padding: 0 5%;">
    <div style="display: flex; gap: 0.8rem; align-items: center; margin-bottom: 2rem;">
        <a href="@Url.Action("Index", "Customer")" style="color: var(--text-dim);"><i class="fas fa-arrow-left"></i> Back to Customers</a>
    </div>

    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2.5rem; box-shadow: var(--shadow-sm); margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid var(--primary-pale); padding-bottom: 1.2rem; margin-bottom: 2rem;">
            <div>
                <h2 style="font-size: 1.6rem; font-weight: 800; color: var(--primary); margin: 0;">
                    <i class="fas fa-user-circle"></i> Customer Profile: @Model.FullName
                </h2>
                <p style="color: var(--text-muted); font-size: 0.95rem; margin-top: 0.2rem;">Account ID: #@Model.Id</p>
            </div>
            <a href="@Url.Action("Edit", "Customer", new { id = Model.Id })" class="btn-primary-sm" style="font-size: 0.85rem; border-radius: 8px; padding: 0.5rem 1rem;">
                <i class="fas fa-edit"></i> Edit Account
            </a>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
            <div>
                <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.4rem;">Email Address</h4>
                <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-main);">@Model.Email</p>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.4rem;">Phone Number</h4>
                <p style="font-size: 1.05rem; font-weight: 600; color: var(--text-main);">@(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</p>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <div>
                <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.4rem;">Account Status</h4>
                @if (Model.IsActive)
                {
                    <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #2da44e; font-weight: 700; font-size: 0.95rem;">
                        <i class="fas fa-check-circle"></i> Active Customer
                    </span>
                }
                else
                {
                    <span style="display: inline-flex; align-items: center; gap: 0.3rem; color: #d35400; font-weight: 700; font-size: 0.95rem;">
                        <i class="fas fa-ban"></i> Suspended / Deactivated
                    </span>
                }
            </div>
            <div>
                <h4 style="font-size: 0.8rem; font-weight: 700; color: var(--text-dim); text-transform: uppercase; margin-bottom: 0.4rem;">Total Orders Placed</h4>
                <p style="font-size: 1.05rem; font-weight: 800; color: var(--primary);">@Model.OrdersCount Orders</p>
            </div>
        </div>
    </div>

    <!-- Saved Addresses Section -->
    <div style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-md); padding: 2.5rem; box-shadow: var(--shadow-sm);">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1.5rem;">
            <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--primary); margin: 0;"><i class="fas fa-map-marker-alt"></i> Shipping Addresses</h3>
            <a href="@Url.Action("Addresses", "Customer", new { customerId = Model.Id })" style="font-size: 0.85rem; font-weight: 700; color: var(--accent); text-decoration: none;">
                Manage Addresses
            </a>
        </div>

        @if (Model.Addresses != null && Model.Addresses.Any())
        {
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
                @foreach (var addr in Model.Addresses)
                {
                    <div style="border: 1.5px solid @(addr.IsDefault ? "var(--primary)" : "var(--border-color)"); background: @(addr.IsDefault ? "var(--primary-pale)" : "white"); border-radius: 12px; padding: 1.2rem; position: relative;">
                        @if (addr.IsDefault)
                        {
                            <span style="position: absolute; top: 12px; right: 12px; font-size: 0.75rem; background: var(--primary); color: white; padding: 2px 8px; border-radius: 20px; font-weight: 700;">DEFAULT</span>
                        }
                        <h4 style="font-size: 0.95rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem; text-transform: uppercase;">@addr.Label</h4>
                        <p style="color: var(--text-main); font-size: 0.9rem; margin-bottom: 0.2rem; font-weight: 600;">@addr.Street</p>
                        <p style="color: var(--text-muted); font-size: 0.85rem;">@addr.City @(string.IsNullOrEmpty(addr.PostalCode) ? "" : $", {addr.PostalCode}")</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p style="color: var(--text-muted); font-size: 0.95rem; text-align: center; padding: 1.5rem 0; margin: 0;">No shipping addresses registered for this customer yet.</p>
        }
    </div>
</div>
