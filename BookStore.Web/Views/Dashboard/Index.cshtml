@{
    ViewData["Title"] = "Admin Dashboard - BookStore";
    var recentOrders = ViewBag.RecentOrders as List<ShopNest.BLL.DTOs.Order.OrderResultDto> ?? new List<ShopNest.BLL.DTOs.Order.OrderResultDto>();
    var recentProducts = ViewBag.RecentProducts as List<ShopNest.BLL.DTOs.Product.ProductResultDto> ?? new List<ShopNest.BLL.DTOs.Product.ProductResultDto>();
}

@section Styles {
    <style>
        .db-container {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 5%;
        }

        .db-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
        }

        .db-header h1 {
            font-size: 1.8rem;
            color: var(--primary);
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .stat-card {
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            padding: 1.5rem;
            box-shadow: var(--shadow-sm);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition);
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-md);
        }

        .stat-info h3 {
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .stat-info p {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }

        .stat-icon.revenue { background: rgba(45, 164, 78, 0.12); color: #2da44e; }
        .stat-icon.orders { background: rgba(52, 152, 219, 0.12); color: #3498db; }
        .stat-icon.books { background: rgba(241, 196, 15, 0.12); color: #f1c40f; }
        .stat-icon.customers { background: rgba(155, 89, 182, 0.12); color: #9b59b6; }

        /* Tables Grid */
        .db-grid-row {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 2.5rem;
            margin-bottom: 3rem;
        }

        .db-card {
            background: white;
            border-radius: var(--radius-md);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .db-card-header {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            background: var(--primary-pale);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .db-card-header h3 {
            font-size: 1.1rem;
            font-weight: 800;
            color: var(--primary);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .db-card-body {
            padding: 1.5rem;
        }

        /* Mini tables */
        .mini-table {
            width: 100%;
            border-collapse: collapse;
        }

        .mini-table th {
            text-align: left;
            padding-bottom: 0.8rem;
            border-bottom: 2px solid var(--border-color);
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.85rem;
        }

        .mini-table td {
            padding: 0.8rem 0;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            vertical-align: middle;
        }

        .mini-table tr:last-child td {
            border-bottom: none;
        }

        /* Order Status badges */
        .status-badge {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.25rem 0.6rem;
            border-radius: 4px;
            text-transform: uppercase;
        }

        .status-badge.pending { background: #fdf3e0; color: #d35400; }
        .status-badge.shipped { background: #ebf5fb; color: #2980b9; }
        .status-badge.delivered { background: #eaf2f8; color: #27ae60; }
        .status-badge.cancelled { background: #fadbd8; color: #c0392b; }

        /* Quick actions */
        .quick-actions-bar {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 3rem;
            background: var(--primary-pale);
            border: 1px solid var(--primary-light);
            padding: 1.5rem;
            border-radius: var(--radius-md);
        }

        .btn-action-db {
            background: white;
            border: 1.5px solid var(--border-color);
            padding: 0.75rem 1.2rem;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 0.88rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }

        .btn-action-db:hover {
            border-color: var(--primary);
            background: var(--primary-pale);
            transform: translateY(-2px);
        }

        @@media (max-width: 900px) {
            .db-grid-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="db-container">
    <div class="db-header">
        <h1><i class="fas fa-chart-line"></i> ShopNest Admin Dashboard</h1>
        <a href="@Url.Action("Index", "Home")" class="btn-primary-sm" style="background: white; color: var(--primary); border: 1.5px solid var(--primary); border-radius: 8px;">
            <i class="fas fa-external-link-alt"></i> Open Book Store
        </a>
    </div>

    <!-- Quick Actions Panel -->
    <div class="quick-actions-bar">
        <h4 style="width: 100%; font-size: 0.95rem; font-weight: 800; color: var(--primary); margin-bottom: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px;">Quick Actions Panel</h4>
        <a href="@Url.Action("Create", "Product")" class="btn-action-db"><i class="fas fa-plus"></i> Add New Book</a>
        <a href="@Url.Action("Index", "Product")" class="btn-action-db"><i class="fas fa-book"></i> Catalog Management</a>
        <a href="@Url.Action("Index", "Category")" class="btn-action-db"><i class="fas fa-layer-group"></i> Categories list</a>
        <a href="@Url.Action("Index", "Order")" class="btn-action-db"><i class="fas fa-shipping-fast"></i> Process Orders</a>
        <a href="@Url.Action("Index", "Customer")" class="btn-action-db"><i class="fas fa-users"></i> Customers list</a>
    </div>

    <!-- Stats Panel -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>EGP @ViewBag.TotalRevenue.ToString("N0")</h3>
                <p>Total Revenue</p>
            </div>
            <div class="stat-icon revenue">
                <i class="fas fa-wallet"></i>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>@ViewBag.TotalOrders</h3>
                <p>Total Orders</p>
            </div>
            <div class="stat-icon orders">
                <i class="fas fa-shopping-bag"></i>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>@ViewBag.TotalProducts</h3>
                <p>Tech Books</p>
            </div>
            <div class="stat-icon books">
                <i class="fas fa-book"></i>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-info">
                <h3>@ViewBag.TotalCustomers</h3>
                <p>Registered Users</p>
            </div>
            <div class="stat-icon customers">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>

    <!-- Details lists -->
    <div class="db-grid-row">
        <!-- Recent Orders Card -->
        <div class="db-card">
            <div class="db-card-header">
                <h3><i class="fas fa-clock"></i> Recent Customer Orders</h3>
                <a href="@Url.Action("Index", "Order")" style="font-size: 0.85rem; font-weight: 700; color: var(--accent);">View All</a>
            </div>
            <div class="db-card-body">
                @if (recentOrders.Any())
                {
                    <table class="mini-table">
                        <thead>
                            <tr>
                                <th>Order ID</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th style="text-align: right;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in recentOrders)
                            {
                                <tr>
                                    <td style="font-weight: 700; color: var(--primary);">#@order.Id</td>
                                    <td style="color: var(--text-muted);">@order.OrderDate.ToString("yyyy-MM-dd")</td>
                                    <td style="font-weight: 700;">EGP @order.TotalAmount.ToString("N0")</td>
                                    <td>
                                        <span class="status-badge @order.Status.ToString().ToLower()">
                                            @order.Status.ToString()
                                        </span>
                                    </td>
                                    <td style="text-align: right;">
                                        <a href="@Url.Action("Details", "Order", new { id = order.Id })" style="color: var(--accent); font-weight: 700; font-size: 0.85rem;">
                                            Process
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p style="text-align: center; color: var(--text-muted); font-size: 0.95rem; padding: 2rem 0;">No orders registered yet.</p>
                }
            </div>
        </div>

        <!-- Recent Books Added -->
        <div class="db-card">
            <div class="db-card-header">
                <h3><i class="fas fa-sparkles"></i> Recently Added Books</h3>
                <a href="@Url.Action("Index", "Product")" style="font-size: 0.85rem; font-weight: 700; color: var(--accent);">Manage Catalog</a>
            </div>
            <div class="db-card-body">
                @if (recentProducts.Any())
                {
                    <table class="mini-table">
                        <thead>
                            <tr>
                                <th>Book Title</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th style="text-align: right;">Stock</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in recentProducts)
                            {
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 0.8rem;">
                                            <div style="width: 32px; height: 42px; background: #faf8f3; border: 1px solid var(--border-color); border-radius: 4px; display: flex; align-items: center; justify-content: center; padding: 0.2rem; flex-shrink: 0;">
                                                <img src="@(string.IsNullOrEmpty(book.MainImagePath) ? "/images/default-book.png" : book.MainImagePath)" style="max-height: 100%; max-width: 100%; object-fit: contain;" onerror="this.src='/images/default-book.png'">
                                            </div>
                                            <div style="max-width: 150px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 700; color: var(--text-main);">
                                                @book.Name
                                            </div>
                                        </div>
                                    </td>
                                    <td style="color: var(--text-muted);">@book.CategoryName</td>
                                    <td style="font-weight: 700; color: var(--primary);">EGP @book.Price.ToString("N0")</td>
                                    <td style="text-align: right; font-weight: 700; color: @(book.Stock <= 5 ? "var(--error)" : "var(--text-main)");">
                                        @book.Stock
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p style="text-align: center; color: var(--text-muted); font-size: 0.95rem; padding: 2rem 0;">No books in catalog yet.</p>
                }
            </div>
        </div>
    </div>
</div>
