@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Access Denied - BookStore";
}

<div class="access-denied-wrapper">
    <div class="container-xl">
        <div class="access-denied-card card-glass animate-up">
            <div class="denied-icon">
                <i class="fas fa-hand-holding-hand"></i>
                <div class="shield-overlay">
                    <i class="fas fa-shield-halved"></i>
                </div>
            </div>
            <h1>Access Denied</h1>
            <p class="error-code">Error 403: Forbidden</p>
            <p class="description">
                You do not have the required administrative permissions to access this page. 
                Please contact support if you believe this is an error, or log in with an administrator account.
            </p>
            <div class="action-buttons">
                <a href="@Url.Action("Index", "Home")" class="btn-action-outline">
                    <i class="fas fa-home"></i> Back to Home
                </a>
                <a href="@Url.Action("Login", "Account")" class="btn-action-primary">
                    <i class="fas fa-sign-in-alt"></i> Sign in as Admin
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .access-denied-wrapper {
            padding: 80px 0;
            background-color: var(--bg-page);
            min-height: 75vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .access-denied-card {
            max-width: 600px;
            width: 100%;
            margin: 0 auto;
            padding: 3.5rem 2.5rem;
            text-align: center;
            border-radius: var(--radius-md);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-md);
        }

        .denied-icon {
            position: relative;
            font-size: 4.5rem;
            color: var(--accent);
            margin-bottom: 2rem;
            display: inline-block;
            animation: pulseShield 2s infinite ease-in-out;
        }

        .shield-overlay {
            position: absolute;
            bottom: -5px;
            right: -10px;
            font-size: 2.2rem;
            color: var(--error);
            background: var(--bg-page);
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        @@keyframes pulseShield {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.05);
            }
        }

        .access-denied-card h1 {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--primary-dark);
            margin-bottom: 0.5rem;
        }

        .error-code {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--error);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 1.5rem;
        }

        .description {
            font-size: 1.05rem;
            color: var(--text-muted);
            line-height: 1.7;
            margin-bottom: 2.5rem;
        }

        .action-buttons {
            display: flex;
            gap: 1.25rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-action-primary {
            background-color: var(--primary);
            color: white;
            padding: 0.8rem 1.8rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            box-shadow: var(--shadow-sm);
        }

        .btn-action-primary:hover {
            background-color: var(--primary-mid);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
            color: white;
        }

        .btn-action-outline {
            background-color: white;
            border: 2px solid var(--border-color);
            color: var(--text-muted);
            padding: 0.8rem 1.8rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
        }

        .btn-action-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-2px);
        }

        .animate-up {
            opacity: 0;
            transform: translateY(20px);
            animation: cardUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        @@keyframes cardUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
}
