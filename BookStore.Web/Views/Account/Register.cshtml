@model ShopNest.Web.ViewModels.Account.RegisterViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register - BookStore";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}

<div class="auth-container">
    <div class="auth-form-container">
        <div class="auth-form-header">
            <div class="auth-logo">
                <i class="fas fa-book-open"></i>
                <h1>BookStore</h1>
            </div>
            <h2 class="auth-form-title">Create Your Account</h2>
            <p class="auth-form-subtitle">It takes only a minute to join our tech community</p>
        </div>
        
        <form class="auth-form" method="post" asp-action="Register" asp-controller="Account">
            @Html.AntiForgeryToken()
            
            <div asp-validation-summary="ModelOnly" class="alert alert-error" style="font-size: 0.9rem; padding: 0.8rem; margin-bottom: 1rem; border-radius: 8px;"></div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="FirstName">First Name</label>
                    <div class="input-icon">
                        <i class="fas fa-user"></i>
                        <input type="text" asp-for="FirstName" placeholder="John" required>
                    </div>
                    <span asp-validation-for="FirstName" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                </div>
                
                <div class="form-group">
                    <label asp-for="LastName">Last Name</label>
                    <div class="input-icon">
                        <i class="fas fa-user"></i>
                        <input type="text" asp-for="LastName" placeholder="Doe" required>
                    </div>
                    <span asp-validation-for="LastName" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                </div>
            </div>
            
            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <div class="input-icon">
                    <i class="fas fa-envelope"></i>
                    <input type="email" asp-for="Email" placeholder="you@example.com" required>
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone">Phone Number</label>
                <div class="input-icon">
                    <i class="fas fa-phone"></i>
                    <input type="text" asp-for="Phone" placeholder="01012345678" required>
                </div>
                <span asp-validation-for="Phone" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" asp-for="Password" id="regPass" placeholder="••••••••" required>
                    <span class="password-toggle" id="toggleRegPass"><i class="fas fa-eye"></i></span>
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
                <div class="password-strength">
                    <div class="strength-meter">
                        <div class="strength-level" id="strengthLevel"></div>
                    </div>
                    <span class="strength-text" id="strengthText">Weak</span>
                </div>
            </div>
            
            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" asp-for="ConfirmPassword" id="regConfirmPass" placeholder="••••••••" required>
                    <span class="password-toggle" id="toggleRegConfirmPass"><i class="fas fa-eye"></i></span>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 0.8rem; color: var(--error);"></span>
            </div>
            
            <div class="form-options">
                <div class="terms">
                    <input type="checkbox" id="terms" name="terms" required>
                    <label for="terms">I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></label>
                </div>
            </div>
            
            <button type="submit" class="btn-primary-full">Create Account</button>
            
            <div class="auth-separator">
                <span>or sign up with</span>
            </div>
            
            <div class="social-login">
                <button type="button" class="social-btn google">
                    <i class="fab fa-google"></i>
                    Google
                </button>
                <button type="button" class="social-btn facebook">
                    <i class="fab fa-facebook-f"></i>
                    Facebook
                </button>
            </div>
            
            <div class="auth-footer">
                <p>Already have an account? <a href="@Url.Action("Login", "Account")">Login</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Password toggles
            const toggleRegPass = document.getElementById('toggleRegPass');
            const toggleRegConfirmPass = document.getElementById('toggleRegConfirmPass');
            const regPass = document.getElementById('regPass');
            const regConfirmPass = document.getElementById('regConfirmPass');
            
            if (toggleRegPass && regPass) {
                toggleRegPass.addEventListener('click', function() {
                    const type = regPass.getAttribute('type') === 'password' ? 'text' : 'password';
                    regPass.setAttribute('type', type);
                    this.querySelector('i').classList.toggle('fa-eye');
                    this.querySelector('i').classList.toggle('fa-eye-slash');
                });
            }
            
            if (toggleRegConfirmPass && regConfirmPass) {
                toggleRegConfirmPass.addEventListener('click', function() {
                    const type = regConfirmPass.getAttribute('type') === 'password' ? 'text' : 'password';
                    regConfirmPass.setAttribute('type', type);
                    this.querySelector('i').classList.toggle('fa-eye');
                    this.querySelector('i').classList.toggle('fa-eye-slash');
                });
            }
            
            // Password strength meter
            if (regPass) {
                regPass.addEventListener('input', function() {
                    const val = this.value;
                    const level = document.getElementById('strengthLevel');
                    const text = document.getElementById('strengthText');
                    
                    let strength = 0;
                    if (val.length >= 6) strength++;
                    if (/[A-Z]/.test(val)) strength++;
                    if (/[0-9]/.test(val)) strength++;
                    if (/[^A-Za-z0-9]/.test(val)) strength++;
                    
                    level.className = 'strength-level';
                    
                    if (val.length === 0) {
                        level.style.width = '0';
                        text.textContent = 'Weak';
                    } else if (strength <= 1) {
                        level.style.width = '25%';
                        level.classList.add('weak');
                        text.textContent = 'Weak';
                        text.style.color = '#e74c3c';
                    } else if (strength === 2) {
                        level.style.width = '50%';
                        level.classList.add('medium');
                        text.textContent = 'Medium';
                        text.style.color = '#f39c12';
                    } else if (strength === 3) {
                        level.style.width = '75%';
                        level.classList.add('good');
                        text.textContent = 'Good';
                        text.style.color = '#3498db';
                    } else {
                        level.style.width = '100%';
                        level.classList.add('strong');
                        text.textContent = 'Strong';
                        text.style.color = '#2ecc71';
                    }
                });
            }
        });
    </script>
    
    <style>
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        @@media (max-width: 480px) {
            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }
        }
        .strength-meter {
            height: 6px;
            background: #e0e0e0;
            border-radius: 3px;
            margin-top: 6px;
            overflow: hidden;
            width: 100%;
        }
        .strength-level {
            height: 100%;
            width: 0;
            transition: all 0.3s ease;
        }
        .strength-level.weak { background: #e74c3c; }
        .strength-level.medium { background: #f39c12; }
        .strength-level.good { background: #3498db; }
        .strength-level.strong { background: #2ecc71; }
        .password-strength {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 4px;
        }
        .strength-text {
            font-size: 0.8rem;
            font-weight: 600;
        }
    </style>
}