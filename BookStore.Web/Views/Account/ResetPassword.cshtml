@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reset Password - BookStore";
}


@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" />
}
<div class="auth-container">
    <div class="auth-form-container">
        <div class="auth-form-header">
            <div class="auth-logo">
                <i class="fas fa-book-open"></i>
                <h1>BookStore</h1>
            </div>
            <h2 class="auth-form-title">Create New Password</h2>
            <p class="auth-form-subtitle">Your new password must be different from previous passwords</p>
        </div>
        
        <form class="auth-form">
            <div class="form-group">
                <label for="newPassword">New Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" id="newPassword" name="newPassword" placeholder="••••••••" required>
                    <span class="password-toggle"><i class="fas fa-eye"></i></span>
                </div>
                <div class="password-requirements">
                    <ul>
                        <li><i class="fas fa-check-circle"></i> At least 8 characters</li>
                        <li><i class="fas fa-check-circle"></i> Contains uppercase and lowercase letters</li>
                        <li><i class="fas fa-check-circle"></i> Includes a number or special character</li>
                    </ul>
                </div>
            </div>
            
            <div class="form-group">
                <label for="confirmPassword">Confirm New Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••" required>
                    <span class="password-toggle"><i class="fas fa-eye"></i></span>
                </div>
            </div>
            
            <button type="submit" class="btn-primary-full">Reset Password</button>
            
            <div class="auth-footer">
                <p><a href="@Url.Action("Login", "Account")"><i class="fas fa-arrow-left"></i> Back to Login</a></p>
            </div>
        </form>
    </div>
</div>